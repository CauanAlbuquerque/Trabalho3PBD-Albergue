-- 5. TABELA ASSOCIATIVA: VAGAS E SUAS CARACTERÍSTICAS
CREATE TABLE tb_vaga_possui_caracteristica (
    id_vaga INT NOT NULL,
    id_caracteristica INT NOT NULL,
    PRIMARY KEY (id_vaga, id_caracteristica),
    FOREIGN KEY (id_vaga) REFERENCES tb_vaga(id_vaga) ON DELETE CASCADE,
    FOREIGN KEY (id_caracteristica) REFERENCES tb_caracteristica_vaga(id_caracteristica) ON DELETE CASCADE
);

-- 6. TABELA DE RESERVAS
CREATE TABLE tb_reserva (
    id_reserva SERIAL PRIMARY KEY,
    id_cliente INT NOT NULL,
    data_inicio TIMESTAMP NOT NULL,
    data_fim TIMESTAMP NOT NULL,
    preco_total NUMERIC(10, 2) NOT NULL,
    status_reserva VARCHAR(20) NOT NULL DEFAULT 'confirmada',
    data_limite_cancelamento TIMESTAMP NOT NULL,
    FOREIGN KEY (id_cliente) REFERENCES tb_cliente(id_cliente) ON DELETE RESTRICT
);


-- 7. TABELA ASSOCIATIVA: ITENS DA RESERVA
CREATE TABLE tb_item_reserva (
    id_reserva INT NOT NULL,
    id_vaga INT NOT NULL,
    PRIMARY KEY (id_reserva, id_vaga),
    FOREIGN KEY (id_reserva) REFERENCES tb_reserva(id_reserva) ON DELETE CASCADE,
    FOREIGN KEY (id_vaga) REFERENCES tb_vaga(id_vaga) ON DELETE RESTRICT
);

-- 8. TABELA DE PAGAMENTOS
CREATE TABLE tb_pagamento (
    id_pagamento SERIAL PRIMARY KEY,
    id_reserva INT NOT NULL,
    metodo_pagamento VARCHAR(30) NOT NULL DEFAULT 'cartao_credito',
    token_cartao VARCHAR(255) NOT NULL,
    valor NUMERIC(10, 2) NOT NULL,
    data_pagamento TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    status_pagamento VARCHAR(20) NOT NULL DEFAULT 'pago',
    FOREIGN KEY (id_reserva) REFERENCES tb_reserva(id_reserva) ON DELETE CASCADE
);  
