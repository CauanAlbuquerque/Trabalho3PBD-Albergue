-- 1. TABELA DE CLIENTES
CREATE TABLE tb_cliente (
    id_cliente SERIAL PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    telefone VARCHAR(20),
    cpf_passaporte VARCHAR(30) UNIQUE NOT NULL
);

-- 2. TABELA DE QUARTOS
CREATE TABLE tb_quarto (
    id_quarto SERIAL PRIMARY KEY,
    numero_quarto VARCHAR(10) UNIQUE NOT NULL,
    capacidade INT NOT NULL,
    possui_banheiro BOOLEAN NOT NULL DEFAULT FALSE
);

-- 3. TABELA DE VAGAS (CAMAS)
CREATE TABLE tb_vaga (
    id_vaga SERIAL PRIMARY KEY,
    id_quarto INT NOT NULL,
    FOREIGN KEY (id_quarto) REFERENCES tb_quarto(id_quarto) ON DELETE CASCADE
);

-- 4. TABELA DE CARACTERÍSTICAS DAS VAGAS
CREATE TABLE tb_caracteristica_vaga (
    id_caracteristica SERIAL PRIMARY KEY,
    descricao VARCHAR(50) UNIQUE NOT NULL
);

